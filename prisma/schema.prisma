// KSI HDFC BANK Ledger Vouchers — pulled via Tally "Ledger Vouchers" report
// keyed by LEDGERNAME=HDFC BANK. Captures every voucher type that touched
// HDFC (Receipt, Payment, Contra, Journal). UI filters by vchType + FY.
model KsiHdfcReceipt {
  id            Int       @id @default(autoincrement())
  fy            String    // "25-26", "26-27"
  date          DateTime
  vchNumber     String
  vchType       String    // "Receipt", "Payment", etc.
  partyName     String    // counter-party ledger
  amount        Float     // absolute rupee value
  direction     String    // "in" or "out"
  narration     String?   // bank narration — usually has UPI/NEFT refs inline
  instrumentNo  String?   // BANKALLOCATIONS.INSTRUMENTNUMBER (NEFT/cheque)
  bankRef       String?   // BANKALLOCATIONS.UNIQUEREFERENCENUMBER
  // Manual classification — user marks rows as not related to sales/process
  // party ledgers (loans, refunds, internal transfers, etc.). Hidden from
  // the default view; survives re-syncs because the sync route only writes
  // sync-derived fields on upsert, leaving these untouched.
  hidden        Boolean   @default(false)
  hiddenReason  String?
  hiddenAt      DateTime?
  // Manual carry-over for prior-FY (e.g. FY 24-25) bills that the user
  // doesn't want to itemise. Reduces the receipt's pool before FIFO
  // when bulk-linking, and counts toward Δ on the list page so a
  // receipt can read fully matched without explicit invoice rows.
  carryOverPriorFy Float  @default(0)
  // Set the moment a successful "Push to Tally" completes (receipt
  // ALTER + any TDS / Discount journals). The detail-page Push button
  // disables when this is non-null to prevent accidental duplicate
  // journal vouchers. Clearing it (via a force-repush path) re-enables.
  tallyPushedAt DateTime?
  lastSynced    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  @@unique([vchNumber, date, vchType], name: "vch_natural_key")
  @@index([fy, direction])
  @@index([fy, hidden])
  @@index([fy, date])

  allocations KsiReceiptAllocation[]
}

// KSI Sales-side invoices pulled from Tally (Process Job = GST invoice with
// CGST/SGST/IGST; Local Job Delivery = matching delivery challan, same
// vchNumber, no GST). Stored together so each party's history shows both.
model KsiSalesInvoice {
  id            Int       @id @default(autoincrement())
  fy            String    // "25-26", "26-27"
  date          DateTime
  vchNumber     String
  vchType       String    // "Process Job" | "Local Job Delivery"
  partyName     String
  partyGstin    String?
  stateName     String?
  placeOfSupply String?
  // Money — totalAmount stored as abs (Tally records party-credit as -ve).
  totalAmount   Float
  taxableAmount Float?    // sum of item-line amounts
  cgstAmount    Float?
  sgstAmount    Float?
  igstAmount    Float?
  roundOff      Float?
  // Free text + references
  narration     String?
  reference     String?
  buyerPO       String?
  transporter   String?
  agentName     String?
  // User-driven skip flag: when true, bulk-link FIFO passes over this
  // invoice. Survives Tally re-syncs because the sync route only writes
  // sync-derived fields on upsert. Pattern mirrors KsiHdfcReceipt.hidden.
  skipAutoLink       Boolean   @default(false)
  skipAutoLinkReason String?
  skipAutoLinkAt     DateTime?
  lastSynced    DateTime  @default(now())
  createdAt     DateTime  @default(now())

  lines       KsiSalesInvoiceLine[]
  ledgers     KsiSalesInvoiceLedger[]
  allocations KsiReceiptAllocation[]

  @@unique([vchNumber, date, vchType], name: "ksi_sales_natural_key")
  @@index([fy, partyName])
  @@index([fy, date])
  @@index([partyName, date])
  @@index([skipAutoLink])
}

// Item-level lines for a sales invoice — keeps the raw qty/rate strings
// (Tally returns " 420.0 THAN" / "175.00/THAN") plus parsed numeric fallbacks.
// altQty/altUnit captures dual-unit qty when present (e.g. "834.00 MTR = 35 PCS").
model KsiSalesInvoiceLine {
  id          Int             @id @default(autoincrement())
  invoiceId   Int
  invoice     KsiSalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  lineNo      Int
  stockItem   String
  rawQty      String?
  qty         Float?
  unit        String?
  altQty      Float?
  altUnit     String?
  rate        Float?
  rateUnit    String?
  amount      Float
  discountPct Float?
  baleNo      String?

  @@index([invoiceId])
}

// All non-item ledger entries on a sales invoice — taxes, discounts, freight,
// extra charges, party ledger, etc. Stored verbatim so the user can map any
// new ledger name encountered to a category for net-sales computation.
model KsiSalesInvoiceLedger {
  id                Int             @id @default(autoincrement())
  invoiceId         Int
  invoice           KsiSalesInvoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  ledgerName        String
  amount            Float           // signed (Tally convention)
  isDeemedPositive  Boolean

  @@index([invoiceId])
  @@index([ledgerName])
}

// User-driven classification of voucher-level ledger names. One row per
// ledger name (case-insensitive). Used to compute net sales = items + extra
// charges − discounts. Sync routes never touch this table.
model KsiSalesLedgerCategory {
  id          Int      @id @default(autoincrement())
  ledgerName  String   @unique
  category    String   // 'extra-charge' | 'discount' | 'tax' | 'party' | 'ignore'
  note        String?
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())

  @@index([category])
}

// Manual reconciliation: a receipt linked to one or more sales/process
// invoices. User-driven, never touched by sync routes.
//
// pending(invoice) = totalAmount − Σ(allocatedAmount + tdsAmount + discountAmount)
//   allocatedAmount = cash from the receipt
//   tdsAmount       = TDS the customer deducted at source (Section 194C etc.)
//   discountAmount  = discount/rebate given to settle the bill
model KsiReceiptAllocation {
  id              Int              @id @default(autoincrement())
  receiptId       Int
  receipt         KsiHdfcReceipt   @relation(fields: [receiptId], references: [id], onDelete: Cascade)
  invoiceId       Int
  invoice         KsiSalesInvoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  allocatedAmount Float
  tdsAmount       Float            @default(0)
  discountAmount  Float            @default(0)
  tdsRatePct      Float?           // e.g. 2.0 — kept for audit; not load-bearing
  note            String?
  // All allocations created in one bulk-link operation share the same
  // UUID. Single-receipt links (from the detail page) leave it NULL.
  bulkBatchId     String?
  createdAt       DateTime         @default(now())

  @@unique([receiptId, invoiceId])
  @@index([receiptId])
  @@index([invoiceId])
  @@index([bulkBatchId])
}

