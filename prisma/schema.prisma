generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Master Tables (Dynamic Dropdowns) ────────────────────────────────────────

model Party {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  tag             String?         // "Pali PC Job", "Local", "Direct", etc.
  createdAt       DateTime        @default(now())
  greyEntries     GreyEntry[]
  despatchEntries DespatchEntry[]
  foldBatchLots   FoldBatchLot[]
  finishRecipes     FinishRecipe[]
  finishRecipeTags  FinishRecipeTag[]
}

model Weaver {
  id          Int         @id @default(autoincrement())
  name        String      @unique
  createdAt   DateTime    @default(now())
  greyEntries GreyEntry[]
}

model Quality {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  createdAt       DateTime        @default(now())
  greyEntries     GreyEntry[]
  despatchEntries DespatchEntry[]
  despatchLots    DespatchEntryLot[]
  foldBatchLots   FoldBatchLot[]
  finishRecipes     FinishRecipe[]
  finishRecipeTags  FinishRecipeTag[]
}

model Transport {
  id              Int             @id @default(autoincrement())
  name            String          @unique
  createdAt       DateTime        @default(now())
  greyEntries     GreyEntry[]
  despatchEntries DespatchEntry[]
}

// ─── Grey Inward Entry ─────────────────────────────────────────────────────────

model GreyEntry {
  id            Int       @id @default(autoincrement())
  sn            Int?      // Serial number from source spreadsheet
  date          DateTime
  challanNo     Int
  partyId       Int
  party         Party     @relation(fields: [partyId], references: [id])
  qualityId     Int
  quality       Quality   @relation(fields: [qualityId], references: [id])
  weight        String?   // e.g. "106g", "114g", "(RG)"
  than          Int
  grayMtr       Float?
  transportId   Int
  transport     Transport @relation(fields: [transportId], references: [id])
  transportLrNo String?
  bale          Int?
  baleNo        String?
  echBaleThan   Float?
  weaverId      Int
  weaver        Weaver    @relation(fields: [weaverId], references: [id])
  viverNameBill String?
  lrNo          String?
  lotNo         String
  marka         String?
  // stock & tDesp are calculated live — not stored
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// ─── Jet Dyeing Machine ────────────────────────────────────────────────────
model DyeingMachine {
  id        Int              @id @default(autoincrement())
  number    Int              @unique
  name      String
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  entries   DyeingEntry[]
  additions DyeingAddition[]
}

// ─── Dyeing Operator ───────────────────────────────────────────────────────
model DyeingOperator {
  id        Int              @id @default(autoincrement())
  name      String           @unique
  mobileNo  String?
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  entries   DyeingEntry[]
  additions DyeingAddition[]
}

// ─── Dyeing Slip Entry ─────────────────────────────────────────────────────────

model DyeingEntry {
  id              Int                  @id @default(autoincrement())
  date            DateTime
  slipNo          Int
  lotNo           String
  than            Int
  shadeName       String?
  notes           String?
  foldBatchId     Int?
  foldBatch       FoldBatch?           @relation(fields: [foldBatchId], references: [id])
  dyeingDoneAt    DateTime?
  dyeingPhotoUrl  String?
  dyeingDriveId   String?
  dyeingNotes     String?
  machineId       Int?
  machine         DyeingMachine?   @relation(fields: [machineId], references: [id])
  operatorId      Int?
  operator        DyeingOperator?  @relation(fields: [operatorId], references: [id])
  colorC          Float?
  colorM          Float?
  colorY          Float?
  colorK          Float?
  colorHex        String?
  isPcJob         Boolean              @default(false)
  marka           String?
  partyInstructions String?
  status          String               @default("pending")   // pending|patchy|re-dyeing|done
  totalRounds     Int                  @default(1)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  chemicals       DyeingSlipChemical[]
  lots            DyeingEntryLot[]
  additions       DyeingAddition[]
}

model DyeingEntryLot {
  id      Int         @id @default(autoincrement())
  entryId Int
  entry   DyeingEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lotNo   String
  than    Int
}

model DyeingSlipChemical {
  id         Int          @id @default(autoincrement())
  entryId    Int
  entry      DyeingEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chemicalId Int?
  chemical   Chemical?    @relation(fields: [chemicalId], references: [id])
  name       String
  quantity   Float?
  unit       String       @default("kg")
  rate       Float?
  cost       Float?
  processTag String?      // "shade" | "Scouring" | "Anti Fungus" | process name
  createdAt  DateTime     @default(now())
}

// ─── Dyeing Addition (for additions and re-dye rounds) ───────────────────────

model DyeingAddition {
  id            Int                     @id @default(autoincrement())
  entryId       Int
  entry         DyeingEntry             @relation(fields: [entryId], references: [id], onDelete: Cascade)
  roundNo       Int
  type          String                  // "addition" | "re-dye"
  defectType    String?                 // "patchy"|"uneven"|"light"|"dark"|"spots"
  defectPhoto   String?
  defectDriveId String?
  reason        String?
  time          String?
  machineId     Int?
  machine       DyeingMachine?          @relation(fields: [machineId], references: [id])
  operatorId    Int?
  operator      DyeingOperator?         @relation(fields: [operatorId], references: [id])
  chemicals     DyeingAdditionItem[]
  createdAt     DateTime                @default(now())
}

model DyeingAdditionItem {
  id            Int              @id @default(autoincrement())
  additionId    Int
  addition      DyeingAddition   @relation(fields: [additionId], references: [id], onDelete: Cascade)
  chemicalId    Int?
  chemical      Chemical?        @relation(fields: [chemicalId], references: [id])
  name          String
  quantity      Float
  unit          String           @default("kg")
  rate          Float?
  cost          Float?
}

// ─── Re-Process Lots ──────────────────────────────────────────────────────────

model ReProcessLot {
  id        Int                @id @default(autoincrement())
  reproNo   String             @unique   // "RE-PRO-1", "RE-PRO-2"
  quality   String                       // shared quality from source lots
  weight    String?                      // from originals
  grayMtr   Float?                       // sum of source meters
  totalThan Int                          // sum of all source thans
  reason    String                       // "patchy" | "daagi" | "shade_mismatch" | "other"
  notes     String?
  status    String             @default("pending") // pending | in-dyeing | finished | merged
  mergedAt  DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  sources   ReProcessSource[]
}

model ReProcessSource {
  id            Int            @id @default(autoincrement())
  reprocessId   Int
  reprocess     ReProcessLot   @relation(fields: [reprocessId], references: [id], onDelete: Cascade)
  originalLotNo String
  than          Int
  party         String?
  reason        String?
  sourceDyeSlip Int?
  createdAt     DateTime       @default(now())
}

// ─── Chemical Master ───────────────────────────────────────────────────────────

model Chemical {
  id           Int                    @id @default(autoincrement())
  name         String                 @unique
  unit         String                 @default("kg")
  category     String?                // 'color' | 'auxiliary'
  currentPrice Float?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  priceHistory   ChemicalPriceHistory[]
  slipUsages     DyeingSlipChemical[]
  finishUsages   FinishSlipChemical[]
  aliases        ChemicalAlias[]
  recipeUsages   ShadeRecipeItem[]
  processItems   DyeingProcessItem[]
  additionUsages DyeingAdditionItem[]
  finishRecipeItems FinishRecipeItem[]
  finishAdditionChemicals FinishAdditionChemical[]
}

model ChemicalPriceHistory {
  id         Int      @id @default(autoincrement())
  chemicalId Int
  chemical   Chemical @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  price      Float
  source     String   @default("manual") // "manual" | "inward_sheet"
  note       String?
  date       DateTime @default(now())
  createdAt  DateTime @default(now())
}

// ─── Chemical Alias (OCR learning) ───────────────────────────────────────────

model ChemicalAlias {
  id         Int      @id @default(autoincrement())
  ocrName    String   @unique   // normalized OCR text e.g. "bezafix"
  chemicalId Int
  chemical   Chemical @relation(fields: [chemicalId], references: [id], onDelete: Cascade)
  hitCount   Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Dyeing Process Presets ──────────────────────────────────────────────────

model DyeingProcess {
  id          Int                 @id @default(autoincrement())
  name        String              @unique
  description String?
  threshold   Float               @default(220) // kg — below this uses quantity, above uses quantityHigh
  createdAt   DateTime            @default(now())
  items       DyeingProcessItem[]
}

model DyeingProcessItem {
  id           Int           @id @default(autoincrement())
  processId    Int
  process      DyeingProcess @relation(fields: [processId], references: [id], onDelete: Cascade)
  chemicalId   Int
  chemical     Chemical      @relation(fields: [chemicalId], references: [id])
  quantity     Float
  quantityHigh Float?        // quantity when batch weight > threshold
  @@unique([processId, chemicalId])
}

// ─── Dyeing Draft Queue (cloud save) ────────────────────────────────────────

model DyeingDraftBatch {
  id        Int                @id @default(autoincrement())
  userId    String             // email of the user
  status    String             @default("active") // active | completed
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  items     DyeingDraftItem[]
}

model DyeingDraftItem {
  id          Int               @id @default(autoincrement())
  batchId     Int
  batch       DyeingDraftBatch  @relation(fields: [batchId], references: [id], onDelete: Cascade)
  imageBase64 String            // base64 encoded image data
  mediaType   String            @default("image/jpeg")
  status      String            @default("pending") // pending | saved | skipped
  sortOrder   Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

// ─── Finish/Center Entry ─────────────────────────────────────────────────────

model FinishEntry {
  id         Int                  @id @default(autoincrement())
  date       DateTime
  slipNo     Int
  lotNo      String               // backward compat: first lot
  than       Int                  // backward compat: first lot's than
  meter      Float?               // total meter
  mandi      Float?               // mandi in liters (legacy)
  opMandi      Float?               // opening mandi (litres)
  newMandi     Float?               // new mandi added (litres)
  stockMandi   Float?               // stock mandi remaining (litres)
  finishThan   Int?                 // total than actually finished
  finishMtr    Float?               // total finish meters
  finishDespSlipNo String?           // finish despatch slip number
  notes        String?
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  chemicals  FinishSlipChemical[]
  lots       FinishEntryLot[]
  additions  FinishAddition[]
}

model FinishEntryLot {
  id       Int          @id @default(autoincrement())
  entryId  Int
  entry    FinishEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lotNo    String
  than     Int
  meter    Float?
  doneThan Int          @default(0)
  status   String       @default("pending") // pending | partial | done
  foldingReceipts FoldingReceipt[]
}

model FoldingReceipt {
  id         Int            @id @default(autoincrement())
  lotEntryId Int
  lotEntry   FinishEntryLot @relation(fields: [lotEntryId], references: [id], onDelete: Cascade)
  slipNo     String
  date       DateTime
  than       Int
  notes      String?
  createdAt  DateTime       @default(now())
}

model FinishSlipChemical {
  id         Int          @id @default(autoincrement())
  entryId    Int
  entry      FinishEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  chemicalId Int?
  chemical   Chemical?    @relation(fields: [chemicalId], references: [id])
  name       String
  quantity   Float?
  unit       String       @default("kg")
  rate       Float?
  cost       Float?
  createdAt  DateTime     @default(now())
}

model FinishAddition {
  id        Int                      @id @default(autoincrement())
  entryId   Int
  entry     FinishEntry              @relation(fields: [entryId], references: [id], onDelete: Cascade)
  reason    String?
  createdAt DateTime                 @default(now())
  chemicals FinishAdditionChemical[]
}

model FinishAdditionChemical {
  id         Int             @id @default(autoincrement())
  additionId Int
  addition   FinishAddition  @relation(fields: [additionId], references: [id], onDelete: Cascade)
  chemicalId Int?
  chemical   Chemical?       @relation(fields: [chemicalId], references: [id])
  name       String
  quantity   Float?
  unit       String          @default("kg")
}

// ─── Despatch Entry ────────────────────────────────────────────────────────────

model DespatchEntry {
  id          Int       @id @default(autoincrement())
  date        DateTime
  challanNo   Int
  partyId     Int
  party       Party     @relation(fields: [partyId], references: [id])
  qualityId   Int
  quality     Quality   @relation(fields: [qualityId], references: [id])
  grayInwDate DateTime?
  lotNo       String
  jobDelivery String?
  than        Int
  billNo      String?
  rate        Float?
  pTotal      Float?    // Auto: than × rate
  lrNo        String?
  transportId Int?
  transport   Transport? @relation(fields: [transportId], references: [id])
  bale        Int?
  narration   String?   // descriptive text from despatch sheet quality column
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  changeLogs  DespatchChangeLog[]
  despatchLots DespatchEntryLot[]
}

model DespatchEntryLot {
  id          Int            @id @default(autoincrement())
  entryId     Int
  entry       DespatchEntry  @relation(fields: [entryId], references: [id], onDelete: Cascade)
  lotNo       String
  than        Int
  meter       Float?
  rate        Float?
  amount      Float?
  description String?
  qualityId   Int?
  quality     Quality?       @relation(fields: [qualityId], references: [id])
}

model DespatchChangeLog {
  id        Int           @id @default(autoincrement())
  entryId   Int
  entry     DespatchEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  field     String        // "than" | "lotNo" | "rate" | "billNo"
  oldValue  String
  newValue  String
  changedBy String        // user email
  createdAt DateTime      @default(now())
}

model DespatchNotification {
  id        Int      @id @default(autoincrement())
  entryId   Int
  challanNo Int
  lotNo     String
  message   String
  userEmail String
  dismissed Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── Encrypted Document Vault ────────────────────────────────────────────────

model VaultConfig {
  id           Int      @id @default(autoincrement())
  passwordHash String   // bcrypt hash of vault password
  salt         String   // salt for key derivation
  createdAt    DateTime @default(now())
}

model VaultEntity {
  id         Int             @id @default(autoincrement())
  type       String          // company | person | huf | property
  encName    String          // AES encrypted name
  encDetails String          // AES encrypted JSON (PAN, GST, etc.)
  iv         String          // initialization vector for encryption
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt
  documents  VaultDocument[]
}

model VaultDocument {
  id             Int          @id @default(autoincrement())
  entityId       Int
  entity         VaultEntity  @relation(fields: [entityId], references: [id], onDelete: Cascade)
  encFileName    String       // AES encrypted original filename
  encFileData    String?      // AES encrypted file data (base64) — for small files in DB
  blobUrl        String?      // For large files stored externally (future)
  fileSize       Int          // original file size in bytes
  mimeType       String       // application/pdf, image/jpeg, etc.
  iv             String       // initialization vector
  encTags        String?      // AES encrypted comma-separated tags (e.g. "aadhaar,id proof")
  encDescription String?      // AES encrypted description/notes
  expiryDate     DateTime?    // plain — needed for expiry queries
  createdAt      DateTime     @default(now())
  notifications  VaultNotification[]
}

model VaultNotification {
  id           Int            @id @default(autoincrement())
  documentId   Int
  document     VaultDocument  @relation(fields: [documentId], references: [id], onDelete: Cascade)
  userEmail    String
  entityName   String         // plain text copy for notification display
  entityType   String         // company/person/huf/property
  docName      String         // plain text copy of filename for notification
  expiryDate   DateTime       // copy of expiry date
  dismissed    Boolean        @default(false)
  lastEmailed  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  @@unique([documentId, userEmail])
}

// ─── Fold Program Module ─────────────────────────────────────────────────────

model Shade {
  id          Int               @id @default(autoincrement())
  name        String            @unique
  description String?
  createdAt   DateTime          @default(now())
  foldBatches FoldBatch[]
  recipeItems ShadeRecipeItem[]
}

model ShadeRecipeItem {
  id         Int      @id @default(autoincrement())
  shadeId    Int
  shade      Shade    @relation(fields: [shadeId], references: [id], onDelete: Cascade)
  chemicalId Int
  chemical   Chemical @relation(fields: [chemicalId], references: [id])
  quantity   Float    // per 100 kg fabric or %
  isPercent  Boolean  @default(false)
}

model FoldProgram {
  id          Int         @id @default(autoincrement())
  foldNo      String      @unique
  date        DateTime
  status      String      @default("draft") // draft | confirmed
  notes       String?
  isPcJob     Boolean     @default(false)
  confirmedAt DateTime?
  batches     FoldBatch[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

model FoldBatch {
  id            Int            @id @default(autoincrement())
  foldProgramId Int
  foldProgram   FoldProgram    @relation(fields: [foldProgramId], references: [id], onDelete: Cascade)
  batchNo          Int
  shadeId          Int?
  shade            Shade?         @relation(fields: [shadeId], references: [id])
  shadeName        String?        // free-text shade name (if not in master)
  shadeDescription String?
  marka            String?
  lots             FoldBatchLot[]
  dyeingEntries    DyeingEntry[]
}

model FoldBatchLot {
  id          Int       @id @default(autoincrement())
  foldBatchId Int
  foldBatch   FoldBatch @relation(fields: [foldBatchId], references: [id], onDelete: Cascade)
  lotNo       String
  partyId     Int?
  party       Party?    @relation(fields: [partyId], references: [id])
  qualityId   Int?
  quality     Quality?  @relation(fields: [qualityId], references: [id])
  than        Int
  createdAt   DateTime  @default(now())
}

model FoldingSlip {
  id        Int              @id @default(autoincrement())
  slipNo    String           @unique
  date      DateTime
  status    String           @default("draft") // draft | confirmed
  notes     String?
  lots      FoldingSlipLot[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
}

model FoldingSlipLot {
  id            Int         @id @default(autoincrement())
  foldingSlipId Int
  foldingSlip   FoldingSlip @relation(fields: [foldingSlipId], references: [id], onDelete: Cascade)
  lotNo         String
  than          Int
  meter         Float?
}

model PackingEntry {
  id         Int          @id @default(autoincrement())
  packingNo  String       @unique
  date       DateTime
  status     String       @default("draft") // draft | confirmed
  notes      String?
  lots       PackingLot[]
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
}

model PackingLot {
  id             Int          @id @default(autoincrement())
  packingEntryId Int
  packingEntry   PackingEntry @relation(fields: [packingEntryId], references: [id], onDelete: Cascade)
  lotNo          String
  than           Int
  boxes          Int?
  notes          String?
}

// ─── Carry-Forward / Opening Balance ─────────────────────────────────────────

model LotOpeningBalance {
  id              Int      @id @default(autoincrement())
  lotNo           String   @unique
  financialYear   String   // "2025-26"
  openingThan     Int      // carry-forward stock
  greyThan        Int?     // original grey than from last year
  totalDespatched Int?     // total despatched last year
  party           String?  // party name for reference
  quality         String?  // quality for reference
  weight          String?  // e.g. "90g", ".98g"
  grayMtr         Float?   // total gray meters
  greyDate        DateTime? // original grey inward date
  marka           String?
  notes           String?
  createdAt       DateTime @default(now())
  despatchHistory LotCarryForwardDespatch[]
  allocations     LotOpeningBalanceAllocation[]
}

model LotOpeningBalanceAllocation {
  id        Int               @id @default(autoincrement())
  balanceId Int
  balance   LotOpeningBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  stage     String            // 'dyed' | 'finished' | 'packed'
  than      Int
  notes     String?
  createdAt DateTime          @default(now())
}

model LotCarryForwardDespatch {
  id        Int               @id @default(autoincrement())
  balanceId Int
  balance   LotOpeningBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  challanNo String?
  than      Int?
  billNo    String?
  rate      Float?
  setNo     Int               // 1, 2, 3, or 4
}

// ─── Tally Integration ──────────────────────────────────────────────────────

model TallyLedger {
  id             Int      @id @default(autoincrement())
  firmCode       String   // "VI", "VCF", "VF"
  name           String
  parent         String?
  address        String?
  gstNo          String?
  panNo          String?
  mobileNos      String?  // original comma-separated
  mobileNo1      String?  // parsed first number
  mobileNo2      String?  // parsed second number
  mobileNo3      String?  // parsed third number
  state          String?
  stateCode      String?
  openingBalance Float?
  closingBalance Float?
  tags           String[] @default([])
  lastSynced     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  @@unique([firmCode, name])
}

// ─── Tally Outstanding ───────────────────────────────────────────────────────

model TallyOutstanding {
  id             Int      @id @default(autoincrement())
  firmCode       String
  partyName      String
  parent         String?  // Sundry Debtors / Sundry Creditors
  type           String   // "receivable" | "payable"
  billRef        String   // invoice/bill reference
  billDate       DateTime?
  dueDate        DateTime?
  overdueDays    Int      @default(0)
  closingBalance Float    @default(0)
  vchType        String?  // Sales, Receipt, Journal, Purchase
  vchNumber      String?
  vchAmount      Float?
  lastSynced     DateTime?
  createdAt      DateTime @default(now())
  @@unique([firmCode, partyName, billRef, type])
}

// ─── Tally Sales ────────────────────────────────────────────────────────────

model TallySales {
  id           Int      @id @default(autoincrement())
  firmCode     String
  date         DateTime?
  vchNumber    String?
  partyName    String?
  itemName     String?
  quantity     Float?
  unit         String?
  rate         Float?
  amount       Float?
  vchType      String?  // Sales, Credit Note etc
  narration    String?
  lastSynced   DateTime?
  createdAt    DateTime @default(now())
  @@index([firmCode, partyName])
}

// ─── Tally Receipt/Payment ──────────────────────────────────────────────────

model TallyReceipt {
  id         Int      @id @default(autoincrement())
  firmCode   String
  date       DateTime?
  vchNumber  String?
  partyName  String?
  amount     Float?
  vchType    String?  // Receipt, Payment
  narration  String?
  lastSynced DateTime?
  createdAt  DateTime @default(now())
  @@index([firmCode, partyName])
}

// ─── Sales Orders (Google Sheets) ─────────────────────────────────────────────

model SalesOrder {
  id           Int      @id @default(autoincrement())
  firmCode     String
  date         String?
  orderNo      String?
  partyOrderNo String?
  partyName    String?
  itemName     String?
  orderQty     Float?
  dispatchMtr  Float?
  desDate      String?
  balance      Float?
  rate         Float?
  discount     String?
  agentName    String?
  remark       String?
  status       String?
  lastSynced   DateTime?
  createdAt    DateTime @default(now())
  @@index([firmCode, partyName])
  @@index([firmCode, agentName])
}

// ─── Contacts ─────────────────────────────────────────────────────────────────

model Contact {
  id            Int      @id @default(autoincrement())
  firmCode      String
  name          String
  mobile1       String?
  mobile2       String?
  mobile3       String?
  contactPerson String?
  tag           String?
  agentName     String?
  address       String?
  state         String?
  gstNo         String?
  source        String?
  lastSynced    DateTime?
  createdAt     DateTime @default(now())
  @@unique([firmCode, name])
  @@index([firmCode, tag])
}

// ─── Call Log ─────────────────────────────────────────────────────────────────

model CallLog {
  id            Int      @id @default(autoincrement())
  partyName     String
  firmCode      String?
  callDate      DateTime
  note          String?
  promiseDate   DateTime?
  promiseAmt    Float?
  nextFollowUp  DateTime?
  calledBy      String?
  createdAt     DateTime @default(now())
  @@index([partyName])
}

// ─── Bank Payments ────────────────────────────────────────────────────────────

model BankPayment {
  id           Int      @id @default(autoincrement())
  firmCode     String
  voucherDate  String?
  description  String?
  instNo       String?
  partyName    String?
  withdrawal   Float?
  deposit      Float?
  narration    String?
  paymentDays  Int?
  source       String?
  lastSynced   DateTime?
  createdAt    DateTime @default(now())
  @@index([firmCode, partyName])
}

// ─── Lot Manual Reservation ───────────────────────────────────────────────────

model LotManualReservation {
  id          Int      @id @default(autoincrement())
  lotNo       String   @unique
  usedThan    Int      // how many than are manually marked as used
  note        String?  // optional reason (e.g. "dyeing batch march")
  updatedBy   String   // user email
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

// ─── Shade Import Queue ───────────────────────────────────────────────────────

model ShadeImportQueue {
  id           Int      @id @default(autoincrement())
  userId       String   // user email
  imageBase64  String   // base64 encoded image
  mediaType    String   @default("image/jpeg")
  driveFileId  String?  // Google Drive file ID (once uploaded)
  driveUrl     String?  // Google Drive view URL
  pageLabel    String?  // "Page 1", "Page 2" etc
  status       String   @default("pending") // pending | processing | reviewing | done | skipped
  ocrRaw       String?  // raw GPT-4 Vision response
  recipes      Json?    // extracted recipes array
  savedCount   Int      @default(0)
  sortOrder    Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ─── Finish Recipe Master ───────────────────────────────────────────────────

model FinishRecipe {
  id          Int                @id @default(autoincrement())
  partyId     Int
  party       Party              @relation(fields: [partyId], references: [id])
  qualityId   Int
  quality     Quality            @relation(fields: [qualityId], references: [id])
  variant     String             @default("Standard")
  isDefault   Boolean            @default(true)
  finishWidth String?
  finalWidth  String?
  shortage    String?
  notes       String?
  items       FinishRecipeItem[]
  tags        FinishRecipeTag[]
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  @@unique([partyId, qualityId, variant])
}

model FinishRecipeItem {
  id         Int           @id @default(autoincrement())
  recipeId   Int
  recipe     FinishRecipe  @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  chemicalId Int?
  chemical   Chemical?     @relation(fields: [chemicalId], references: [id])
  name       String
  quantity   Float
  unit       String        @default("kg")
}

model FinishRecipeTag {
  id         Int          @id @default(autoincrement())
  partyId    Int
  party      Party        @relation(fields: [partyId], references: [id])
  qualityId  Int
  quality    Quality      @relation(fields: [qualityId], references: [id])
  recipeId   Int
  recipe     FinishRecipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  createdAt  DateTime     @default(now())
  @@unique([partyId, qualityId])
}

// ─── Inventory Module ─────────────────────────────────────────────────────────

model InventoryCategory {
  id        Int              @id @default(autoincrement())
  name      String           @unique // "Dyes & Auxiliary", "Packing Material", "Machinery Parts", "Fuel", "Interlock Service", "Motor Service", "Others"
  items     InventoryItem[]
  createdAt DateTime         @default(now())
}

model InventoryItem {
  id           Int                    @id @default(autoincrement())
  name         String
  unit         String                 @default("kg")
  categoryId   Int
  category     InventoryCategory      @relation(fields: [categoryId], references: [id])
  chemicalId   Int?                   // link to Chemical master (for dyes/auxiliary)
  minStock     Float?                 // reorder level
  isActive     Boolean                @default(true)
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt
  transactions InventoryTransaction[]
  physicalStock PhysicalStockEntry[]
  aliases      InventoryItemAlias[]
  poItems      PurchaseOrderItem[]
  deliveryItems DeliveryChallanItem[]
  @@unique([name, categoryId])
}

model InventoryTransaction {
  id         Int            @id @default(autoincrement())
  itemId     Int
  item       InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type       String         // "purchase" | "consumed" | "adjustment" | "return"
  quantity   Float
  rate       Float?
  amount     Float?
  date       DateTime
  reference  String?        // invoice no, slip no, memo no
  notes      String?
  createdAt  DateTime       @default(now())
}

model PhysicalStockEntry {
  id         Int            @id @default(autoincrement())
  itemId     Int
  item       InventoryItem  @relation(fields: [itemId], references: [id], onDelete: Cascade)
  date       DateTime       // physical count date
  quantity   Float          // actual quantity found
  notes      String?
  createdAt  DateTime       @default(now())
}

// ─── Purchase Order ───────────────────────────────────────────────────────────

model PurchaseOrder {
  id         Int                 @id @default(autoincrement())
  poNo       String              @unique
  date       DateTime
  partyName  String
  partyMobile String?
  status     String              @default("draft") // draft | sent | partial | delivered | closed
  notes      String?
  items      PurchaseOrderItem[]
  deliveries DeliveryChallan[]
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
}

model PurchaseOrderItem {
  id       Int            @id @default(autoincrement())
  poId     Int
  po       PurchaseOrder  @relation(fields: [poId], references: [id], onDelete: Cascade)
  itemId   Int
  item     InventoryItem  @relation(fields: [itemId], references: [id])
  quantity Float
  rate     Float?
  notes    String?
}

// ─── Delivery Challan (Inward) ────────────────────────────────────────────────

model DeliveryChallan {
  id          Int                   @id @default(autoincrement())
  challanNo   String
  date        DateTime
  partyName   String
  poId        Int?                  // optional link to PO
  po          PurchaseOrder?        @relation(fields: [poId], references: [id])
  notes       String?
  items       DeliveryChallanItem[]
  createdAt   DateTime              @default(now())
}

model DeliveryChallanItem {
  id              Int            @id @default(autoincrement())
  challanId       Int
  challan         DeliveryChallan @relation(fields: [challanId], references: [id], onDelete: Cascade)
  itemId          Int
  item            InventoryItem  @relation(fields: [itemId], references: [id])
  itemDescription String?        // party's name for this item (alias)
  quantity        Float
  rate            Float?
  amount          Float?
}

// ─── Item Alias (party-wise item names) ───────────────────────────────────────

model InventoryItemAlias {
  id        Int           @id @default(autoincrement())
  itemId    Int
  item      InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  partyName String
  alias     String
  usedAt    DateTime      @default(now()) // for "most recently used" sorting
  createdAt DateTime      @default(now())
  @@unique([alias, partyName])
}

// ─── Tally Sync Log ───────────────────────────────────────────────────────────

model TallyConfig {
  id                  Int      @id @default(autoincrement())
  firmCode            String   @unique
  firmName            String
  tallyCompanyName    String
  tallyTunnelUrl      String?
  cfAccessClientId    String?
  cfAccessClientSecret String?
  tallyApiSecret      String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model TallySyncLog {
  id        Int      @id @default(autoincrement())
  type      String   // "ledger" | "outstanding" | "sales"
  company   String   // "KSI" | "VI"
  status    String   // "success" | "failed"
  count     Int      @default(0)
  duration  Float?
  error     String?
  createdAt DateTime @default(now())
}
